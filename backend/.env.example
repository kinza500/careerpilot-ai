# --- Core ---
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://careerpilot_app:app_pw_change_me@db:5432/careerpilot

# --- Auth (generate long random strings) ---
JWT_SECRET=please-change-this-to-a-64-char-random-string
JWT_EXPIRE_MINUTES=1440

# --- Confidentiality: CV encryption at rest (REQUIRED) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CV_ENCRYPTION_KEY=

# --- LLM (privacy-safe API paths only — never the free consumer chat tiers) ---
LLM_PROVIDER=openai              # openai | anthropic | ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1             # or gpt-5.1 / gpt-5.5 for more capability
# Alternatives:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Fully-local / air-gapped (no CV text leaves the host):
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1

# --- Embeddings ---
# Default: OpenAI's API (used whenever LLM_PROVIDER is openai/anthropic —
# resume/job text already goes to that same API for the LLM agents, so this
# doesn't add a new confidentiality boundary). Cheap: ~$0.02 per 1M tokens.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Used instead, locally, only when LLM_PROVIDER=ollama (fully air-gapped):
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Background jobs ---
REDIS_URL=redis://redis:6379/0

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Company research (Tavily search API for agents; optional) ---
TAVILY_API_KEY=

# --- Cheaper model for the Interview Prep agent (optional override) ---
OPENAI_INTERVIEW_MODEL=gpt-4.1-mini

# --- Extra job discovery sources (optional — supplement JobSpy's scrapers) ---
JOOBLE_API_KEY=
SERPAPI_KEY=

# --- Gmail + Calendar integration (OAuth; required for draft/send/reply/
# calendar features). Create credentials in Google Cloud Console and add
# GOOGLE_REDIRECT_URI as an authorized redirect URI. Scopes requested:
# gmail.compose, gmail.readonly, calendar.events, openid, email. ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
